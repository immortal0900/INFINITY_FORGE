{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity-forge.local/schemas/critic-result-v1.schema.json",
  "title": "Forge Critic Result v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "forge-critic-result/v1"
    },
    "outcome": {
      "enum": ["pass", "defect_found"]
    },
    "source_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pr_url": {
      "type": "string",
      "pattern": "^https://github\\.com/[^/]+/[^/]+/pull/[1-9][0-9]*$"
    },
    "reviewed_head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "result_head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "added_tests": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
    },
    "reflection": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  },
  "required": [
    "schema_version",
    "outcome",
    "source_digest",
    "pr_url",
    "reviewed_head_sha",
    "result_head_sha",
    "added_tests",
    "scenarios"
  ],
  "allOf": [
    {
      "if": {
        "properties": {"outcome": {"const": "defect_found"}},
        "required": ["outcome"]
      },
      "then": {"required": ["reflection"]}
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity-forge.local/schemas/reviewer-result-v1.schema.json",
  "title": "Forge Reviewer Result v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "forge-reviewer-result/v1"
    },
    "verdict": {
      "enum": ["approve", "reject"]
    },
    "source_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pr_url": {
      "type": "string",
      "pattern": "^https://github\\.com/[^/]+/[^/]+/pull/[1-9][0-9]*$"
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "delta_check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "implemented_verified": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        },
        "discrepancies": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        }
      },
      "required": ["implemented_verified", "discrepancies"]
    },
    "spec_check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "met": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        },
        "unmet": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        }
      },
      "required": ["met", "unmet"]
    },
    "reflection": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  },
  "required": [
    "schema_version",
    "verdict",
    "source_digest",
    "pr_url",
    "head_sha",
    "delta_check",
    "spec_check"
  ],
  "allOf": [
    {
      "if": {
        "properties": {"verdict": {"const": "reject"}},
        "required": ["verdict"]
      },
      "then": {"required": ["reflection"]}
    }
  ]
}
